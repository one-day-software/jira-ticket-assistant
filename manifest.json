{
  "manifest_version": 3,
  "name": "JIRA Ticket Assistant | OnedaySoftware",
  "author": "OnedaySoftware",
  "version": "1.2.0",
  "description": "Automatically inject ticket templates and improve JIRA ticket content using AI",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs"
  ],
  "action": {
    "default_title": "JIRA Ticket Assistant",
    "default_icon": {
      "16": "static/img/icon.png",
      "32": "static/img/icon.png",
      "48": "static/img/icon.png",
      "128": "static/img/icon.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "static/img/icon.png",
    "32": "static/img/icon.png",
    "48": "static/img/icon.png",
    "128": "static/img/icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "scripts/constants.js",
        "scripts/content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "scripts/background.js"
  }
}